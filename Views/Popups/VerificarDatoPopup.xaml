<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="RoclandAccesoControl.Mobile.Views.Popups.VerificarDatoPopup"
               x:TypeArguments="x:Boolean"
               BackgroundColor="#FFFFFFFF"
               CanBeDismissedByTappingOutsideOfPopup="False">
    <Border BackgroundColor="#FFFFFF"
            StrokeShape="RoundRectangle 20,20,0,0"
            Stroke="Transparent"
            Padding="24,28,24,40">
        <Border.Shadow>
            <Shadow Brush="#000000" Offset="0,-4" Radius="20" Opacity="0.1"/>
        </Border.Shadow>

        <VerticalStackLayout Spacing="24">
            <Border BackgroundColor="#FEF3C7"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Padding="16"
                    HorizontalOptions="Center">
                <Image Source="icon_check.png" HeightRequest="32" WidthRequest="32"/>
            </Border>

            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label x:Name="LblTitulo" FontSize="18" FontAttributes="Bold"
                       TextColor="#111827" HorizontalOptions="Center"/>
                <Label x:Name="LblInstruccion" FontSize="14" TextColor="#374151"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                <Label x:Name="LblValorEsperado" FontSize="16" FontAttributes="Bold"
                       TextColor="#16A34A" HorizontalOptions="Center"
                       Margin="0,8,0,0" LineBreakMode="WordWrap"/>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border BackgroundColor="#F3F4F6"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        Padding="0,18">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNoCoincide"/>
                    </Border.GestureRecognizers>
                    <Label Text="No coincide" FontSize="15" FontAttributes="Bold"
                           TextColor="#374151" HorizontalOptions="Center"/>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="#16A34A"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        Padding="0,18">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSiCoincide"/>
                    </Border.GestureRecognizers>
                    <Label Text="Sí, coincide" FontSize="15" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center"/>
                </Border>
            </Grid>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>