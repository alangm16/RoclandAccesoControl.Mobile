<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="RoclandAccesoControl.Mobile.Views.Popups.ConfirmarAprobacionPopup"
               x:TypeArguments="x:Boolean"
               BackgroundColor="#FFFFFFFF"
               CanBeDismissedByTappingOutsideOfPopup="True">

    <Border BackgroundColor="#FFFFFF"
            StrokeShape="RoundRectangle 20,20,0,0"
            Stroke="Transparent"
            Padding="24,28,24,40">
        <Border.Shadow>
            <Shadow Brush="#000000" Offset="0,-4" Radius="20" Opacity="0.1"/>
        </Border.Shadow>

        <VerticalStackLayout Spacing="24">

            <Border BackgroundColor="#F0FDF4"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Padding="16"
                    HorizontalOptions="Center">
                <Image Source="icon_check.png" HeightRequest="32" WidthRequest="32"/>
            </Border>

            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                <Label Text="Confirmar aprobación"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="#111827" HorizontalOptions="Center"/>
                <Label x:Name="LblNombre"
                       FontSize="15" FontAttributes="Bold"
                       TextColor="#16A34A" HorizontalOptions="Center"/>
                <Label x:Name="LblGafete"
                       FontSize="13" TextColor="#6B7280"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border BackgroundColor="#F3F4F6"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        Padding="0,18">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCancelar"/>
                    </Border.GestureRecognizers>
                    <Label Text="Cancelar" FontSize="15" FontAttributes="Bold"
                           TextColor="#374151" HorizontalOptions="Center"/>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="#16A34A"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        Padding="0,18">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnConfirmar"/>
                    </Border.GestureRecognizers>
                    <Label Text="Aprobar" FontSize="15"
                           FontAttributes="Bold" TextColor="White"
                           HorizontalOptions="Center"/>
                </Border>
            </Grid>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>