<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:models="clr-namespace:RoclandAccesoControl.Mobile.Models"
    x:Class="RoclandAccesoControl.Mobile.Views.Popups.GafeteSelectorPopup"
    x:TypeArguments="models:GafeteDisponible"
    CanBeDismissedByTappingOutsideOfPopup="True">

    <Border BackgroundColor="#FFFFFF"
            StrokeShape="RoundRectangle 20,20,0,0"
            Stroke="Transparent"
            Padding="0,20,0,36">

        <Border.Shadow>
            <Shadow Brush="#000000" Offset="0,-4" Radius="20" Opacity="0.12"/>
        </Border.Shadow>

        <VerticalStackLayout Spacing="0">

            <!-- Handle + título -->
            <BoxView WidthRequest="36" HeightRequest="4"
                     Color="#E5E7EB"
                     CornerRadius="2"
                     HorizontalOptions="Center"
                     Margin="0,0,0,16"/>

            <Label Text="Gafetes disponibles"
                   FontSize="16" FontAttributes="Bold"
                   TextColor="#111827"
                   HorizontalOptions="Center"
                   Margin="0,0,0,4"/>

            <Label x:Name="LblConteo"
                   FontSize="12"
                   TextColor="#9CA3AF"
                   HorizontalOptions="Center"
                   Margin="0,0,0,16"/>

            <BoxView HeightRequest="1" Color="#F3F4F6"/>

            <!-- Lista -->
            <CollectionView x:Name="ListaGafetes"
                            SelectionMode="None"
                            MaximumHeightRequest="420">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:GafeteDisponible">
                        <VerticalStackLayout>

                            <Grid ColumnDefinitions="*,Auto"
                                  Padding="20,14">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="OnGafeteTapped"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>

                                <Label Text="{Binding Codigo}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#111827"
                                       VerticalOptions="Center"/>

                                <Border Grid.Column="1"
                                        BackgroundColor="#F0FDF4"
                                        StrokeShape="RoundRectangle 6"
                                        Stroke="#BBF7D0"
                                        StrokeThickness="1"
                                        Padding="8,4"
                                        VerticalOptions="Center">
                                    <Label Text="Disponible"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#16A34A"/>
                                </Border>
                            </Grid>

                            <BoxView HeightRequest="1"
                                     Color="#F3F4F6"
                                     Margin="20,0"/>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>