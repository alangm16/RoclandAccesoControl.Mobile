<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="RoclandAccesoControl.Mobile.Views.DetalleSolicitudPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RoclandAccesoControl.Mobile.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="vm:DetalleSolicitudViewModel"
             BackgroundColor="#F1F5F1"
             Shell.NavBarIsVisible="True"
             Shell.NavBarHasShadow="False">

    <ContentPage.Resources>
        <toolkit:IsNullConverter x:Key="IsNullConverter"/>
        <toolkit:IsNotNullConverter x:Key="IsNotNullConverter"/>
    </ContentPage.Resources>

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False"/>
    </Shell.BackButtonBehavior>

    <!-- NavBar personalizada -->
    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,0,4,0" ColumnSpacing="10">
            <Image Source="logo_rocland.png" HeightRequest="32" WidthRequest="32"
                   VerticalOptions="Center"/>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                <Label Text="Detalle de solicitud" FontSize="17" FontAttributes="Bold"
                       TextColor="#1A1A1A"/>
                <Label Text="Revisa y decide el acceso" FontSize="11" TextColor="#6B7280"/>
            </VerticalStackLayout>
            <BoxView Grid.Column="2" WidthRequest="28" BackgroundColor="Transparent"/>
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="*,Auto">

        <!-- ── Contenido desplazable ── -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16,16,16,8" Spacing="12">

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding EstaCargando}"
                                   IsVisible="{Binding EstaCargando}"
                                   Color="#22C55E"
                                   HeightRequest="48"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"/>

                <!-- ── Card: encabezado persona ── -->
                <Border BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        Padding="16"
                        IsVisible="{Binding NoEstaCargando}">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Border BackgroundColor="#F0FDF4"
                                StrokeShape="RoundRectangle 12"
                                Stroke="Transparent"
                                Padding="12"
                                VerticalOptions="Center">
                            <Image Source="{Binding Solicitud.TipoIconoSource}"
                                   HeightRequest="30" WidthRequest="30"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                            <Label Text="{Binding Solicitud.NombrePersona}"
                                   FontSize="18" FontAttributes="Bold"
                                   TextColor="#111827"
                                   LineBreakMode="TailTruncation"/>
                            <HorizontalStackLayout Spacing="8">
                                <Border BackgroundColor="{Binding Solicitud.TipoColor}"
                                        StrokeShape="RoundRectangle 6"
                                        Stroke="Transparent"
                                        Padding="8,3">
                                    <Label Text="{Binding Solicitud.TipoRegistro}"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="White"/>
                                </Border>
                                <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                                    <Image Source="icon_clock.png"
                                           HeightRequest="13" WidthRequest="13"
                                           VerticalOptions="Center" Opacity="0.45"/>
                                    <Label Text="{Binding Solicitud.HoraFormateada}"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="#374151" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ── Card: datos del visitante ── -->
                <Border BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        Padding="16"
                        IsVisible="{Binding NoEstaCargando}">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="0">

                        <HorizontalStackLayout Spacing="8" Margin="0,0,0,14">
                            <Image Source="icon_person.png"
                                   HeightRequest="16" WidthRequest="16"
                                   VerticalOptions="Center" Opacity="0.5"/>
                            <Label Text="Información del visitante"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="#374151" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Fila: ID -->
                        <Grid ColumnDefinitions="*,*" Margin="0,0,0,14">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Tipo de identificación"
                                       FontSize="11" TextColor="#6B7280"/>
                                <Label Text="{Binding Solicitud.TipoID}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="#111827"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="3">
                                <Label Text="Número" FontSize="11" TextColor="#6B7280"/>
                                <Label Text="{Binding Solicitud.NumeroIdentificacion}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="#111827"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F3F4F6" Margin="0,0,0,14"/>

                        <!-- Fila: Área / Motivo -->
                        <Grid ColumnDefinitions="*,*" Margin="0,0,0,14">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Área / Empresa"
                                       FontSize="11" TextColor="#6B7280"/>
                                <HorizontalStackLayout Spacing="5">
                                    <Image Source="icon_building.png"
                                           HeightRequest="13" WidthRequest="13"
                                           VerticalOptions="Center" Opacity="0.4"/>
                                    <Label Text="{Binding Solicitud.AreaOEmpresa}"
                                           FontSize="14" TextColor="#111827"
                                           LineBreakMode="TailTruncation"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="3">
                                <Label Text="Motivo de visita"
                                       FontSize="11" TextColor="#6B7280"/>
                                <Label Text="{Binding Solicitud.Motivo}"
                                       FontSize="14" TextColor="#111827"
                                       LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- ── Card: selección de gafete ── -->
                <Border BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        Padding="16"
                        IsVisible="{Binding NoEstaCargando}">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10">

                        <HorizontalStackLayout Spacing="8">
                            <Image Source="icon_badge.png" HeightRequest="16" WidthRequest="16"
                                   VerticalOptions="Center" Opacity="0.5"/>
                            <Label Text="Seleccionar gafete"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="#374151" VerticalOptions="Center"/>
                            <Label Text="* Requerido" FontSize="11" TextColor="#EF4444"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Trigger del selector -->
                        <Border StrokeShape="RoundRectangle 10"
                                StrokeThickness="1.5"
                                Padding="14,0"
                                HeightRequest="52">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <!-- Default = gafete seleccionado -->
                                    <Setter Property="BackgroundColor" Value="#F0FDF4"/>
                                    <Setter Property="Stroke" Value="#BBF7D0"/>
                                    <Style.Triggers>
                                        <!-- Sobrescribe cuando NO hay selección -->
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding GafeteSeleccionado}"
                                                     Value="{x:Null}">
                                            <Setter Property="BackgroundColor" Value="#F9FAFB"/>
                                            <Setter Property="Stroke" Value="#D1D5DB"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding AbrirSelectorGafeteCommand}"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">

                                <!-- Sin selección: placeholder -->
                                <Label Text="Selecciona un gafete"
                                       FontSize="15" TextColor="#9CA3AF"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding GafeteSeleccionado,
                                           Converter={StaticResource IsNullConverter}}"/>

                                <!-- Con selección: badge centrado -->
                                <Border BackgroundColor="#F0FDF4"
                                        StrokeShape="RoundRectangle 8"
                                        Stroke="#BBF7D0"
                                        StrokeThickness="1"
                                        Padding="12,5"
                                        VerticalOptions="Center"
                                        HorizontalOptions="Start"
                                        IsVisible="{Binding GafeteSeleccionado,
                                            Converter={StaticResource IsNotNullConverter}}">
                                    <Label Text="{Binding GafeteSeleccionado.Codigo}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="#16A34A"/>
                                </Border>

                                <!-- Chevron dibujado en XAML — sin archivo PNG -->
                                <Grid Grid.Column="1"
                                      WidthRequest="20" HeightRequest="20"
                                      VerticalOptions="Center">
                                    <Image Source="icon_chevron_down.png"
                                       WidthRequest="16"
                                       HeightRequest="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       Aspect="AspectFit"/>
                                </Grid>

                            </Grid>
                        </Border>

                        <!-- Sin gafetes disponibles -->
                        <Border BackgroundColor="#FEF2F2"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#FECACA"
                                StrokeThickness="1"
                                Padding="12,8"
                                IsVisible="{Binding NoHayGafetes}">
                            <Label Text="No hay gafetes disponibles en este momento."
                                   FontSize="12" TextColor="#DC2626"/>
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Barra de acciones fija abajo ── -->
        <Border Grid.Row="1"
                BackgroundColor="#FFFFFF"
                StrokeShape="RoundRectangle 0"
                Stroke="#E5E7EB"
                StrokeThickness="0"
                Padding="16,12,16,28">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,-3" Radius="10" Opacity="0.06"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="10" IsVisible="{Binding NoEstaCargando}">

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                    <!-- Rechazar -->
                    <Border BackgroundColor="#FEF2F2"
                            StrokeShape="RoundRectangle 12"
                            Stroke="#FECACA"
                            StrokeThickness="1.5"
                            Padding="0"
                            HeightRequest="52">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding RechazarCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               Spacing="8">
                            <Label Text="Rechazar"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="#DC2626" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Aprobar -->
                    <Border Grid.Column="1"
                            BackgroundColor="#16A34A"
                            StrokeShape="RoundRectangle 12"
                            Stroke="Transparent"
                            Padding="0"
                            HeightRequest="52">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding AprobarCommand}"/>
                        </Border.GestureRecognizers>
                        <Border.Shadow>
                            <Shadow Brush="#16A34A" Offset="0,4" Radius="12" Opacity="0.35"/>
                        </Border.Shadow>
                        <HorizontalStackLayout HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               Spacing="8">
                            <Label Text="Aprobar"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <!-- Regresar -->
                <Border BackgroundColor="Transparent"
                        StrokeShape="RoundRectangle 10"
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        Padding="0"
                        HeightRequest="42">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RegresarCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Spacing="6">
                        <Image Source="icon_back.png"
                               HeightRequest="15" WidthRequest="15"
                               VerticalOptions="Center" Opacity="0.45"/>
                        <Label Text="Regresar a solicitudes"
                               FontSize="13" TextColor="#6B7280"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>